<script>
  function syncDistributionConfig(toggle) {
    if (!(toggle instanceof HTMLInputElement)) return;
    const root = toggle.closest("[data-distribution-root]");
    if (!root) return;
    const config = root.querySelector("[data-distribution-config]");
    if (!(config instanceof HTMLElement)) return;
    config.hidden = !toggle.checked;
  }

  function syncAllDistributionConfigs(scope = document) {
    scope.querySelectorAll("[data-distribution-toggle]").forEach((toggle) => {
      if (toggle instanceof HTMLInputElement) {
        syncDistributionConfig(toggle);
      }
    });
  }

  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const confirmSubmitTrigger = target.closest("[data-confirm-submit]");
    if (confirmSubmitTrigger instanceof HTMLButtonElement) {
      const message = confirmSubmitTrigger.dataset.confirmSubmit;
      if (message && !window.confirm(message)) {
        event.preventDefault();
      }
      return;
    }

    const openTrigger = target.closest("[data-open-dialog]");
    if (openTrigger instanceof HTMLElement) {
      const dialogId = openTrigger.dataset.openDialog;
      const dialog = dialogId ? document.getElementById(dialogId) : null;
      if (dialog instanceof HTMLDialogElement) {
        dialog.showModal();
      }
      return;
    }

    const closeTrigger = target.closest("[data-close-dialog]");
    if (closeTrigger instanceof HTMLElement) {
      const dialog = closeTrigger.closest("dialog");
      if (dialog instanceof HTMLDialogElement) {
        dialog.close();
      }
      return;
    }

    const resetTrigger = target.closest("[data-reset-form]");
    if (resetTrigger instanceof HTMLElement) {
      const formNode = resetTrigger.closest("form");
      if (!(formNode instanceof HTMLFormElement)) return;
      formNode.reset();

      formNode.querySelectorAll("[data-rich-editor]").forEach((editorNode) => {
        if (editorNode instanceof HTMLElement) {
          editorNode.innerHTML = "";
        }
      });
      formNode.querySelectorAll("[data-rich-output]").forEach((outputNode) => {
        if (outputNode instanceof HTMLTextAreaElement) {
          outputNode.value = "";
        }
      });

      syncAllDistributionConfigs(formNode);
    }
  });

  document.addEventListener("change", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLInputElement)) return;
    if (!target.matches("[data-distribution-toggle]")) return;
    syncDistributionConfig(target);
  });

  document.addEventListener("input", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLInputElement)) return;
    if (!target.matches("[data-blog-search]")) return;

    const query = target.value.trim().toLowerCase();
    const rows = document.querySelectorAll("[data-blog-row]");
    let visibleCount = 0;

    rows.forEach((row) => {
      if (!(row instanceof HTMLElement)) return;
      const value = row.dataset.blogSearchValue || "";
      const match = !query || value.includes(query);
      row.style.display = match ? "" : "none";
      if (match) visibleCount += 1;
    });

    const emptyState = document.querySelector("[data-blog-empty]");
    if (emptyState instanceof HTMLElement) {
      emptyState.classList.toggle("hidden", visibleCount > 0);
    }
  });

  syncAllDistributionConfigs();

  document.querySelectorAll("dialog[data-admin-dialog]").forEach((dialogNode) => {
    if (!(dialogNode instanceof HTMLDialogElement)) return;

    dialogNode.addEventListener("cancel", () => {
      dialogNode.close();
    });

    dialogNode.addEventListener("click", (event) => {
      if (event.target === dialogNode) {
        dialogNode.close();
      }
    });
  });

  function syncEditorOutput(container) {
    const surface = container.querySelector("[data-rich-editor]");
    const output = container.querySelector("[data-rich-output]");
    if (!(surface instanceof HTMLElement) || !(output instanceof HTMLTextAreaElement)) return;
    output.value = surface.innerHTML.trim();
  }

  async function uploadPastedImage(file, slugHint) {
    const payload = new FormData();
    payload.set("action", "upload-blog-image");
    payload.set("image", file);
    payload.set("slug", slugHint || "blog");

    const response = await fetch("/consultant/api/admin/manage", {
      method: "POST",
      body: payload,
      credentials: "same-origin"
    });

    const json = await response.json();
    if (!response.ok || !json?.ok || !json?.imageUrl) {
      throw new Error(json?.message || "No pudimos subir la imagen pegada.");
    }

    return json.imageUrl;
  }

  function adjustSelectedImageWidth(editor, deltaPercent) {
    const selection = window.getSelection();
    const node = selection?.anchorNode;
    if (!node) return;
    const image = node instanceof HTMLImageElement ? node : node.parentElement?.closest("img");
    if (!(image instanceof HTMLImageElement) || !editor.contains(image)) return;

    const currentWidth = Number.parseInt(image.style.width || "100", 10);
    const nextWidth = Math.max(20, Math.min(100, currentWidth + deltaPercent));
    image.style.width = `${nextWidth}%`;
  }

  function applyFontSize(surface, sizePx) {
    const selection = window.getSelection();
    if (!selection || selection.rangeCount === 0) return;
    const range = selection.getRangeAt(0);
    if (range.collapsed) return;
    const span = document.createElement("span");
    span.style.fontSize = `${sizePx}px`;
    try {
      range.surroundContents(span);
    } catch {
      document.execCommand("fontSize", false, "4");
      surface.querySelectorAll("font[size='4']").forEach((node) => {
        if (node instanceof HTMLElement) {
          node.style.fontSize = `${sizePx}px`;
          node.removeAttribute("size");
        }
      });
    }
  }

  function applyFontFamily(surface, fontFamily) {
    const selection = window.getSelection();
    if (!selection || selection.rangeCount === 0) return;
    const range = selection.getRangeAt(0);
    if (range.collapsed) return;
    if (!fontFamily || fontFamily === "inherit") return;

    const span = document.createElement("span");
    span.style.fontFamily = fontFamily;
    try {
      range.surroundContents(span);
    } catch {
      document.execCommand("fontName", false, fontFamily);
      surface.querySelectorAll("font").forEach((node) => {
        if (node instanceof HTMLElement) {
          node.style.fontFamily = fontFamily;
          node.removeAttribute("face");
        }
      });
    }
  }

  function clearImageSelection(surface) {
    surface.querySelectorAll("img.is-selected").forEach((imageNode) => {
      imageNode.classList.remove("is-selected");
    });
    const wrapperNode = surface.closest(".admin-editor-shell");
    const toolbarNode = wrapperNode?.querySelector(".admin-editor-image-floating");
    if (toolbarNode instanceof HTMLElement) {
      toolbarNode.classList.add("hidden");
    }
  }

  function clearLayoutBlockSelection(surface) {
    surface.querySelectorAll(".editor-layout-block.is-selected").forEach((blockNode) => {
      if (blockNode instanceof HTMLElement) blockNode.classList.remove("is-selected");
    });
  }

  function clearLayoutBlockFocus(surface) {
    surface.querySelectorAll(".editor-layout-block__text").forEach((textNode) => {
      if (textNode instanceof HTMLElement) {
        textNode.blur();
      }
    });
  }

  function placeCaretInLayoutTextBlock(blockNode, clientX, clientY) {
    if (!(blockNode instanceof HTMLElement)) return;
    const textNode = blockNode.querySelector(".editor-layout-block__text");
    if (!(textNode instanceof HTMLElement)) return;

    textNode.focus({ preventScroll: true });

    const clickRange = getRangeFromPoint(clientX, clientY);
    const selection = window.getSelection();
    if (!selection) return;

    const isInsideTextNode =
      clickRange &&
      textNode.contains(clickRange.startContainer) &&
      textNode.contains(clickRange.endContainer);

    selection.removeAllRanges();
    if (isInsideTextNode) {
      selection.addRange(clickRange);
      return;
    }

    const fallbackRange = document.createRange();
    fallbackRange.selectNodeContents(textNode);
    fallbackRange.collapse(false);
    selection.addRange(fallbackRange);
  }

  function ensureFloatingImageToolbar(wrapperNode) {
    const existing = wrapperNode.querySelector(".admin-editor-image-floating");
    if (existing instanceof HTMLElement) return existing;

    const toolbar = document.createElement("div");
    toolbar.className = "admin-editor-image-floating hidden";
    toolbar.innerHTML = `
      <button type="button" data-editor-action="move-image-left">Img ←</button>
      <button type="button" data-editor-action="move-image-right">Img →</button>
      <button type="button" data-editor-action="decrease-image">- Img</button>
      <button type="button" data-editor-action="increase-image">+ Img</button>
    `;
    wrapperNode.appendChild(toolbar);
    return toolbar;
  }

  function getSurfacePoint(surface, clientX, clientY) {
    const rect = surface.getBoundingClientRect();
    return {
      x: Math.max(0, Math.min(rect.width, clientX - rect.left + surface.scrollLeft)),
      y: Math.max(0, Math.min(rect.height, clientY - rect.top + surface.scrollTop))
    };
  }

  async function createLayoutBlock(surface, kind, rect, formNode) {
    const block = document.createElement("div");
    block.className = "editor-layout-block";
    block.dataset.layoutBlock = kind;
    block.style.left = `${rect.x}px`;
    block.style.top = `${rect.y}px`;
    block.style.width = `${Math.max(120, rect.w)}px`;
    block.style.height = `${Math.max(60, rect.h)}px`;

    if (kind === "text") {
      const text = document.createElement("div");
      text.className = "editor-layout-block__text";
      text.contentEditable = "true";
      text.innerHTML = "<p>Escribe aqui...</p>";
      block.appendChild(text);
    } else if (kind === "image") {
      const mode = window.prompt("Imagen: escribe URL / PEGAR / SUBIR", "URL");
      let imageUrl = "";
      if (!mode) return null;
      const normalizedMode = mode.trim().toLowerCase();
      if (normalizedMode === "url") {
        imageUrl = window.prompt("URL de la imagen") ?? "";
      } else if (normalizedMode === "pegar") {
        if (!navigator.clipboard?.read) {
          window.alert("Tu navegador no permite leer imagenes del portapapeles aqui.");
          return null;
        }
        const items = await navigator.clipboard.read();
        const imageClipboardItem = items.find((item) => item.types.some((t) => t.startsWith("image/")));
        if (!imageClipboardItem) {
          window.alert("No encontramos una imagen en el portapapeles.");
          return null;
        }
        const type = imageClipboardItem.types.find((t) => t.startsWith("image/"));
        if (!type) return null;
        const blob = await imageClipboardItem.getType(type);
        const file = new File([blob], `clipboard-${Date.now()}.png`, { type: blob.type || "image/png" });
        const slugInput = formNode?.querySelector("input[name='slug']");
        imageUrl = await uploadPastedImage(file, slugInput instanceof HTMLInputElement ? slugInput.value : "blog");
      } else if (normalizedMode === "subir") {
        const picker = document.createElement("input");
        picker.type = "file";
        picker.accept = "image/png,image/jpeg,image/webp,image/gif";
        const selectedFile = await new Promise((resolve) => {
          picker.addEventListener("change", () => resolve(picker.files?.[0] ?? null), { once: true });
          picker.click();
        });
        if (!(selectedFile instanceof File)) return null;
        const slugInput = formNode?.querySelector("input[name='slug']");
        imageUrl = await uploadPastedImage(selectedFile, slugInput instanceof HTMLInputElement ? slugInput.value : "blog");
      } else {
        window.alert("Usa: URL, PEGAR o SUBIR");
        return null;
      }
      if (!imageUrl) return null;
      block.innerHTML = `<img src="${imageUrl}" style="width:100%;height:100%;object-fit:contain;border-radius:.45rem;" draggable="false" />`;
    } else if (kind === "link") {
      const linkText = window.prompt("Texto del link") ?? "";
      const href = window.prompt("URL del link") ?? "";
      if (!href) return null;
      block.innerHTML = `<a href="${href}" target="_blank" rel="noopener noreferrer" style="color:#ffb979;text-decoration:underline;">${linkText || href}</a>`;
    }

    const resize = document.createElement("span");
    resize.className = "editor-layout-block__resize";
    block.appendChild(resize);
    surface.appendChild(block);
    return block;
  }

  function updateFloatingImageToolbar(wrapperNode, selectedImage) {
    const toolbar = ensureFloatingImageToolbar(wrapperNode);
    if (!(selectedImage instanceof HTMLImageElement)) {
      toolbar.classList.add("hidden");
      return;
    }

    const wrapperRect = wrapperNode.getBoundingClientRect();
    const imageRect = selectedImage.getBoundingClientRect();
    const toolbarWidth = toolbar.offsetWidth || 220;
    const toolbarHeight = toolbar.offsetHeight || 36;
    const desiredLeft = imageRect.left - wrapperRect.left + imageRect.width / 2 - toolbarWidth / 2;
    const left = Math.max(0, Math.min(desiredLeft, wrapperRect.width - toolbarWidth));
    let top = imageRect.bottom - wrapperRect.top + 8;
    const maxTop = Math.max(0, wrapperRect.height - toolbarHeight);
    if (top > maxTop) {
      top = Math.max(0, imageRect.top - wrapperRect.top - toolbarHeight - 8);
    }

    toolbar.style.left = `${left}px`;
    toolbar.style.top = `${top}px`;
    toolbar.classList.remove("hidden");
  }

  function normalizeEditorImages(surface) {
    surface.querySelectorAll("img").forEach((imageNode) => {
      if (!(imageNode instanceof HTMLImageElement)) return;

      const parent = imageNode.parentElement;
      if (parent instanceof HTMLElement && parent.matches("figure.editor-image")) {
        return;
      }

      const figure = document.createElement("figure");
      figure.className = "editor-image is-center";
      parent?.insertBefore(figure, imageNode);
      figure.appendChild(imageNode);
    });

    surface.querySelectorAll("figure.editor-image").forEach((figureNode) => {
      if (!(figureNode instanceof HTMLElement)) return;
      const image = figureNode.querySelector("img");
      const onlyImageChild =
        figureNode.childNodes.length === 1 &&
        figureNode.firstChild instanceof HTMLImageElement;
      if (!onlyImageChild && image) {
        figureNode.replaceChildren(image);
      }
    });
  }

  function ensureEditorImagesInteractive(surface) {
    normalizeEditorImages(surface);

    surface.querySelectorAll("img").forEach((node) => {
      if (!(node instanceof HTMLImageElement)) return;
      node.draggable = true;
      if (!node.style.maxWidth) node.style.maxWidth = "100%";
      if (!node.style.height) node.style.height = "auto";
      if (!node.style.display) node.style.display = "block";
      if (!node.style.width || node.style.width.endsWith("%")) {
        const fallback = Math.round((surface.clientWidth || 800) * 0.6);
        node.style.width = `${Math.max(220, fallback)}px`;
      }
    });
  }

  function getRangeFromPoint(clientX, clientY) {
    if (document.caretPositionFromPoint) {
      const position = document.caretPositionFromPoint(clientX, clientY);
      if (!position) return null;
      const range = document.createRange();
      range.setStart(position.offsetNode, position.offset);
      range.collapse(true);
      return range;
    }

    if (document.caretRangeFromPoint) {
      return document.caretRangeFromPoint(clientX, clientY);
    }

    return null;
  }

  function classifyHorizontalPlacement(surface, clientX) {
    const bounds = surface.getBoundingClientRect();
    const ratio = (clientX - bounds.left) / Math.max(bounds.width, 1);
    if (ratio < 0.33) return "is-left";
    if (ratio > 0.66) return "is-right";
    return "is-center";
  }

  function applyImagePlacementClass(figureNode, placement) {
    if (!(figureNode instanceof HTMLElement)) return;
    figureNode.classList.remove("is-left", "is-right", "is-center", "is-free");
    figureNode.classList.add(placement);
  }

  function applyFreeHorizontalPlacement(surface, figureNode, clientX) {
    if (!(figureNode instanceof HTMLElement)) return;
    const surfaceRect = surface.getBoundingClientRect();
    const figureRect = figureNode.getBoundingClientRect();
    const width = Math.max(1, figureRect.width);
    const maxLeft = Math.max(0, surfaceRect.width - width);
    const targetLeft = Math.min(
      maxLeft,
      Math.max(0, clientX - surfaceRect.left - width / 2)
    );
    const leftPercent = (targetLeft / Math.max(surfaceRect.width, 1)) * 100;

    applyImagePlacementClass(figureNode, "is-free");
    figureNode.style.marginLeft = `${leftPercent.toFixed(2)}%`;
  }

  function adjustSelectedImageHorizontalOffset(surface, deltaPercent) {
    const selectedBlock = surface.querySelector(".editor-layout-block.is-selected");
    if (selectedBlock instanceof HTMLElement) {
      const currentLeft = Number.parseFloat(selectedBlock.style.left || "0") || 0;
      const stepPx = deltaPercent < 0 ? -24 : deltaPercent > 0 ? 24 : 0;
      const maxLeft = Math.max(0, surface.scrollWidth - selectedBlock.offsetWidth - 8);
      const nextLeft = Math.max(0, Math.min(maxLeft, currentLeft + stepPx));
      selectedBlock.style.left = `${nextLeft}px`;
      return;
    }

    let selectedImage = surface.querySelector("img.is-selected");
    if (!(selectedImage instanceof HTMLImageElement)) {
      const selection = window.getSelection();
      const anchorNode = selection?.anchorNode ?? null;
      const anchorElement =
        anchorNode instanceof HTMLElement
          ? anchorNode
          : anchorNode?.parentElement ?? null;
      const fallbackImage = anchorElement?.closest("img");
      if (fallbackImage instanceof HTMLImageElement && surface.contains(fallbackImage)) {
        selectedImage = fallbackImage;
        selectedImage.classList.add("is-selected");
      }
    }
    if (!(selectedImage instanceof HTMLImageElement)) return;
    const figure = selectedImage.closest("figure.editor-image");
    if (!(figure instanceof HTMLElement)) return;
    // Immediate behavior: one click moves to left/right float and text wraps around.
    if (deltaPercent < 0) {
      applyImagePlacementClass(figure, "is-left");
      figure.style.float = "left";
      figure.style.clear = "none";
      figure.style.margin = "0.8rem 1rem 0.8rem 0";
    } else if (deltaPercent > 0) {
      applyImagePlacementClass(figure, "is-right");
      figure.style.float = "right";
      figure.style.clear = "none";
      figure.style.margin = "0.8rem 0 0.8rem 1rem";
    } else {
      applyImagePlacementClass(figure, "is-center");
      figure.style.float = "none";
      figure.style.clear = "both";
      figure.style.margin = "0.9rem auto";
    }
  }

  function moveCaretToParagraphAfterFigure(surface) {
    const selectedImage = surface.querySelector("img.is-selected");
    if (!(selectedImage instanceof HTMLImageElement)) return;
    const figure = selectedImage.closest("figure.editor-image");
    if (!(figure instanceof HTMLElement)) return;

    let target = figure.nextElementSibling;
    if (!(target instanceof HTMLElement)) {
      target = document.createElement("p");
      target.appendChild(document.createElement("br"));
      figure.insertAdjacentElement("afterend", target);
    }

    const range = document.createRange();
    range.selectNodeContents(target);
    range.collapse(false);
    const selection = window.getSelection();
    selection?.removeAllRanges();
    selection?.addRange(range);
    surface.focus();
  }

  function adjustSelectedImageWidthPx(surface, deltaPx) {
    const selectedImage = surface.querySelector("img.is-selected");
    if (!(selectedImage instanceof HTMLImageElement)) return;
    const currentPx = Number.parseFloat((selectedImage.style.width || "0").replace("px", "")) || selectedImage.getBoundingClientRect().width;
    const maxPx = Math.max(260, surface.clientWidth - 40);
    const nextPx = Math.max(120, Math.min(maxPx, currentPx + deltaPx));
    selectedImage.style.width = `${Math.round(nextPx)}px`;
  }

  function bindImageDragAndDrop(surface, wrapperNode) {
    let draggedImage = null;

    surface.addEventListener("dragstart", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLImageElement)) return;
      draggedImage = target;
      target.classList.add("is-dragging");
      event.dataTransfer?.setData("text/plain", "editor-image");
      if (event.dataTransfer) event.dataTransfer.effectAllowed = "move";
    });

    surface.addEventListener("dragover", (event) => {
      if (!draggedImage) return;
      event.preventDefault();
      if (event.dataTransfer) event.dataTransfer.dropEffect = "move";
    });

    surface.addEventListener("drop", (event) => {
      if (!draggedImage) return;
      event.preventDefault();

      const dropTarget = event.target instanceof HTMLElement ? event.target.closest("img") : null;
      if (dropTarget instanceof HTMLImageElement && dropTarget !== draggedImage) {
        const rect = dropTarget.getBoundingClientRect();
        const placeAfter = event.clientY > rect.top + rect.height / 2;
        const dragFigure = draggedImage.closest("figure.editor-image") ?? draggedImage;
        const targetFigure = dropTarget.closest("figure.editor-image") ?? dropTarget;
        targetFigure.parentNode?.insertBefore(
          dragFigure,
          placeAfter ? targetFigure.nextSibling : targetFigure
        );
        applyImagePlacementClass(
          dragFigure instanceof HTMLElement ? dragFigure : null,
          classifyHorizontalPlacement(surface, event.clientX)
        );
        if (dragFigure instanceof HTMLElement) {
          applyFreeHorizontalPlacement(surface, dragFigure, event.clientX);
        }
      } else {
        const range = getRangeFromPoint(event.clientX, event.clientY);
        const dragNode = draggedImage.closest("figure.editor-image") ?? draggedImage;
        const startContainer = range?.startContainer ?? null;
        if (startContainer && dragNode.contains(startContainer)) {
          draggedImage.classList.remove("is-dragging");
          draggedImage.classList.add("is-selected");
          syncEditorOutput(wrapperNode);
          return;
        }
        if (range) {
          try {
            range.insertNode(dragNode);
          } catch {
            surface.appendChild(dragNode);
          }
        } else {
          surface.appendChild(dragNode);
        }
        applyImagePlacementClass(
          dragNode instanceof HTMLElement ? dragNode : null,
          classifyHorizontalPlacement(surface, event.clientX)
        );
        if (dragNode instanceof HTMLElement) {
          applyFreeHorizontalPlacement(surface, dragNode, event.clientX);
        }
      }

      normalizeEditorImages(surface);
      ensureEditorImagesInteractive(surface);
      draggedImage.classList.remove("is-dragging");
      draggedImage.classList.add("is-selected");
      syncEditorOutput(wrapperNode);
    });

    surface.addEventListener("dragend", () => {
      if (!draggedImage) return;
      draggedImage.classList.remove("is-dragging");
      draggedImage = null;
      syncEditorOutput(wrapperNode);
    });
  }

  function bindMouseImageResize(surface, wrapperNode) {
    let activeImage = null;
    let startX = 0;
    let startWidth = 0;

    surface.addEventListener("click", (event) => {
      const target = event.target;
      if (target instanceof HTMLImageElement) {
        const wasSelected = target.classList.contains("is-selected");
        clearImageSelection(surface);
        if (!wasSelected) {
          target.classList.add("is-selected");
          updateFloatingImageToolbar(wrapperNode, target);
        }
        return;
      }
      clearImageSelection(surface);
    });

    surface.addEventListener("mousedown", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLImageElement)) return;
      const bounds = target.getBoundingClientRect();
      const nearRightBottom =
        event.clientX >= bounds.right - 38 && event.clientY >= bounds.bottom - 38;
      if (!nearRightBottom) return;

      event.preventDefault();
      activeImage = target;
      startX = event.clientX;
      startWidth = bounds.width;
      target.classList.add("is-selected");
    });

    window.addEventListener("mousemove", (event) => {
      if (!activeImage) return;
      const delta = event.clientX - startX;
      const surfaceWidth = surface.clientWidth || 1;
      const nextWidthPx = Math.max(120, startWidth + delta);
      const widthPercent = Math.max(20, Math.min(100, (nextWidthPx / surfaceWidth) * 100));
      activeImage.style.width = `${widthPercent}%`;
      syncEditorOutput(wrapperNode);
    });

    window.addEventListener("mouseup", () => {
      activeImage = null;
    });
  }

  function isPointerNearBlockEdge(blockNode, clientX, clientY, threshold = 10) {
    const rect = blockNode.getBoundingClientRect();
    if (
      clientX < rect.left ||
      clientX > rect.right ||
      clientY < rect.top ||
      clientY > rect.bottom
    ) {
      return false;
    }

    const distanceToLeft = clientX - rect.left;
    const distanceToRight = rect.right - clientX;
    const distanceToTop = clientY - rect.top;
    const distanceToBottom = rect.bottom - clientY;

    return (
      distanceToLeft <= threshold ||
      distanceToRight <= threshold ||
      distanceToTop <= threshold ||
      distanceToBottom <= threshold
    );
  }

  document.querySelectorAll("form").forEach((formNode, formIndex) => {
    if (!(formNode instanceof HTMLFormElement)) return;
    let pendingEditorUploads = 0;
    const actionInput = formNode.querySelector("input[name='action']");
    const formAction = actionInput instanceof HTMLInputElement ? actionInput.value : "";
    const shouldPersistDraft = formAction === "create-blog-post";
    const draftKey = `admin-blog-form-draft-${formIndex}`;
    const saveDraftState = () => {
      const data = {};
      formNode.querySelectorAll("input[name], textarea[name], select[name]").forEach((el) => {
        if (el instanceof HTMLInputElement) {
          if (el.type === "file") return;
          if (el.type === "checkbox") data[el.name] = el.checked ? "1" : "0";
          else data[el.name] = el.value;
        } else if (el instanceof HTMLTextAreaElement || el instanceof HTMLSelectElement) {
          data[el.name] = el.value;
        }
      });
      const editor = formNode.querySelector("[data-rich-editor]");
      if (editor instanceof HTMLElement) data.__editor_html = editor.innerHTML;
      sessionStorage.setItem(draftKey, JSON.stringify(data));
    };
    const restoreDraftState = () => {
      const raw = sessionStorage.getItem(draftKey);
      if (!raw) return;
      try {
        const data = JSON.parse(raw);
        formNode.querySelectorAll("input[name], textarea[name], select[name]").forEach((el) => {
          if (el instanceof HTMLInputElement) {
            if (el.type === "file") return;
            if (el.type === "checkbox") el.checked = data[el.name] === "1";
            else if (typeof data[el.name] === "string") el.value = data[el.name];
          } else if (el instanceof HTMLTextAreaElement || el instanceof HTMLSelectElement) {
            if (typeof data[el.name] === "string") el.value = data[el.name];
          }
        });
        const editor = formNode.querySelector("[data-rich-editor]");
        if (editor instanceof HTMLElement && typeof data.__editor_html === "string") {
          editor.innerHTML = data.__editor_html;
        }
      } catch {}
    };
    if (shouldPersistDraft) {
      restoreDraftState();
    }

    const editorWrappers = formNode.querySelectorAll(".admin-editor-shell");
    editorWrappers.forEach((wrapperNode) => {
      if (!(wrapperNode instanceof HTMLElement)) return;
      const surface = wrapperNode.querySelector("[data-rich-editor]");
      if (!(surface instanceof HTMLElement)) return;
      const drawAreaButton = wrapperNode.querySelector("[data-editor-action='draw-area']");
      let contentTool = "text";
      let drawMode = false;
      let ghost = null;
      let drawStart = null;
      let draggingBlock = null;
      let dragOffset = { x: 0, y: 0 };
      let resizingBlock = null;
      let resizeStart = null;
      let selectedBlockMode = "none"; // none | block | text
      const setDrawMode = (enabled) => {
        drawMode = enabled;
        surface.classList.toggle("is-draw-mode", drawMode);
        if (drawAreaButton instanceof HTMLElement) {
          drawAreaButton.classList.toggle("is-active", drawMode);
        }
        if (!drawMode && ghost) {
          ghost.remove();
          ghost = null;
        }
      };

      wrapperNode.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        const command = target.getAttribute("data-editor-command");
        const action = target.getAttribute("data-editor-action");
        if (!command && !action) return;

        event.preventDefault();
        surface.focus();

        if (command === "createLink") {
          const url = window.prompt("URL del link");
          if (url) document.execCommand("createLink", false, url);
        } else if (command === "insertImage") {
          const url = window.prompt("URL de la imagen");
          if (url) document.execCommand("insertImage", false, url);
        } else if (command) {
          document.execCommand(command, false);
        }

        if (action === "draw-area") {
          setDrawMode(!drawMode);
          return;
        }

        if (action === "increase-image") adjustSelectedImageWidthPx(surface, 30);
        if (action === "decrease-image") adjustSelectedImageWidthPx(surface, -30);
        if (action === "move-image-left") {
          adjustSelectedImageHorizontalOffset(surface, -3);
          moveCaretToParagraphAfterFigure(surface);
        }
        if (action === "move-image-right") {
          adjustSelectedImageHorizontalOffset(surface, 3);
          moveCaretToParagraphAfterFigure(surface);
        }
        updateFloatingImageToolbar(wrapperNode, surface.querySelector("img.is-selected"));
        syncEditorOutput(wrapperNode);
      });

      wrapperNode.querySelectorAll(".admin-editor-toolbar button").forEach((buttonNode) => {
        if (!(buttonNode instanceof HTMLButtonElement)) return;
        buttonNode.addEventListener("mousedown", (event) => {
          event.preventDefault();
        });
      });

      wrapperNode.querySelectorAll(".admin-editor-toolbar select").forEach((selectNode) => {
        if (!(selectNode instanceof HTMLSelectElement)) return;
        selectNode.addEventListener("mousedown", (event) => {
          event.stopPropagation();
        });
      });

      wrapperNode.addEventListener("change", (event) => {
        const target = event.target;
        if (!(target instanceof HTMLSelectElement)) return;
        const editorSelect = target.getAttribute("data-editor-select");
        if (!editorSelect) return;
        surface.focus();

        if (editorSelect === "content-type") {
          contentTool = target.value || "text";
          target.classList.add("is-active");
          setDrawMode(true);
          return;
        }

        if (editorSelect === "font-size") {
          const nextSize = Number.parseInt(target.value, 10);
          if (!Number.isNaN(nextSize)) {
            applyFontSize(surface, nextSize);
          }
        }

        if (editorSelect === "font-family") {
          applyFontFamily(surface, target.value);
        }

        syncEditorOutput(wrapperNode);
      });

      surface.addEventListener("input", () => {
        normalizeEditorImages(surface);
        ensureEditorImagesInteractive(surface);
        updateFloatingImageToolbar(wrapperNode, surface.querySelector("img.is-selected"));
        syncEditorOutput(wrapperNode);
      });
      surface.addEventListener("mousedown", (event) => {
        if (!(event.target instanceof HTMLElement)) return;
        if (event.target.closest(".admin-editor-toolbar")) return;
        if (event.target.closest(".admin-editor-image-floating")) return;
        const clickedBlock = event.target.closest(".editor-layout-block");
        if (!(clickedBlock instanceof HTMLElement)) {
          selectedBlockMode = "none";
          clearLayoutBlockSelection(surface);
          clearLayoutBlockFocus(surface);
        }

        const resizeHandle = event.target.closest(".editor-layout-block__resize");
        if (resizeHandle instanceof HTMLElement) {
          resizingBlock = resizeHandle.closest(".editor-layout-block");
          if (resizingBlock instanceof HTMLElement) {
            const rect = resizingBlock.getBoundingClientRect();
            resizeStart = {
              x: event.clientX,
              y: event.clientY,
              w: rect.width,
              h: rect.height
            };
            event.preventDefault();
            return;
          }
        }

        const block = clickedBlock;
        if (block instanceof HTMLElement && !drawMode) {
          const textBlock = event.target.closest(".editor-layout-block__text");
          surface.querySelectorAll(".editor-layout-block.is-selected").forEach((node) => {
            if (node instanceof HTMLElement) node.classList.remove("is-selected");
          });
          block.classList.add("is-selected");
          clearImageSelection(surface);

          if (
            textBlock instanceof HTMLElement &&
            !isPointerNearBlockEdge(block, event.clientX, event.clientY)
          ) {
            selectedBlockMode = "text";
            placeCaretInLayoutTextBlock(block, event.clientX, event.clientY);
            draggingBlock = null;
            return;
          }

          selectedBlockMode = "block";
          draggingBlock = block;
          const point = getSurfacePoint(surface, event.clientX, event.clientY);
          dragOffset = {
            x: point.x - (Number.parseFloat(block.style.left || "0") || 0),
            y: point.y - (Number.parseFloat(block.style.top || "0") || 0)
          };
          event.preventDefault();
          return;
        }

        if (drawMode) {
          selectedBlockMode = "none";
          drawStart = getSurfacePoint(surface, event.clientX, event.clientY);
          ghost = document.createElement("div");
          ghost.className = "admin-editor-draw-ghost";
          ghost.style.left = `${drawStart.x}px`;
          ghost.style.top = `${drawStart.y}px`;
          ghost.style.width = "0px";
          ghost.style.height = "0px";
          surface.appendChild(ghost);
          event.preventDefault();
          return;
        }

        const image = event.target.closest("img");
        if (image instanceof HTMLImageElement) {
          selectedBlockMode = "none";
          clearLayoutBlockSelection(surface);
          const wasSelected = image.classList.contains("is-selected");
          clearImageSelection(surface);
          if (!wasSelected) {
            image.classList.add("is-selected");
            updateFloatingImageToolbar(wrapperNode, image);
          }
        } else {
          selectedBlockMode = "none";
          clearLayoutBlockSelection(surface);
          clearImageSelection(surface);
        }
        surface.focus();
      });
      window.addEventListener("mousemove", (event) => {
        if (drawMode && drawStart && ghost) {
          const point = getSurfacePoint(surface, event.clientX, event.clientY);
          const left = Math.min(drawStart.x, point.x);
          const top = Math.min(drawStart.y, point.y);
          const width = Math.abs(point.x - drawStart.x);
          const height = Math.abs(point.y - drawStart.y);
          ghost.style.left = `${left}px`;
          ghost.style.top = `${top}px`;
          ghost.style.width = `${width}px`;
          ghost.style.height = `${height}px`;
          return;
        }

        if (draggingBlock) {
          const point = getSurfacePoint(surface, event.clientX, event.clientY);
          const x = Math.max(0, point.x - dragOffset.x);
          const y = Math.max(0, point.y - dragOffset.y);
          draggingBlock.style.left = `${x}px`;
          draggingBlock.style.top = `${y}px`;
          syncEditorOutput(wrapperNode);
          return;
        }

        if (resizingBlock && resizeStart) {
          const nextW = Math.max(100, resizeStart.w + (event.clientX - resizeStart.x));
          const nextH = Math.max(50, resizeStart.h + (event.clientY - resizeStart.y));
          resizingBlock.style.width = `${nextW}px`;
          resizingBlock.style.height = `${nextH}px`;
          syncEditorOutput(wrapperNode);
        }
      });
      window.addEventListener("mouseup", () => {
        if (drawMode && drawStart && ghost) {
          const left = Number.parseFloat(ghost.style.left || "0");
          const top = Number.parseFloat(ghost.style.top || "0");
          const width = Number.parseFloat(ghost.style.width || "0");
          const height = Number.parseFloat(ghost.style.height || "0");
          ghost.remove();
          ghost = null;
          drawStart = null;

          if (width >= 16 && height >= 16) {
            const block = createLayoutBlock(surface, contentTool, { x: left, y: top, w: width, h: height }, formNode);
            Promise.resolve(block).then((resolvedBlock) => {
            if (resolvedBlock) {
              surface.querySelectorAll(".editor-layout-block.is-selected").forEach((node) => {
                if (node instanceof HTMLElement) node.classList.remove("is-selected");
              });
              resolvedBlock.classList.add("is-selected");
              selectedBlockMode = "block";
              syncEditorOutput(wrapperNode);
            }
            });
          }
          setDrawMode(false);
        }
        draggingBlock = null;
        resizingBlock = null;
        resizeStart = null;
      });
      surface.addEventListener("blur", () => syncEditorOutput(wrapperNode));
      surface.addEventListener("keydown", (event) => {
        if (event.key !== "Delete" && event.key !== "Backspace") return;

        const selectedBlock = surface.querySelector(".editor-layout-block.is-selected");
        if (!(selectedBlock instanceof HTMLElement)) return;

        if (selectedBlockMode === "text") {
          return;
        }

        event.preventDefault();
        selectedBlock.remove();
        selectedBlockMode = "none";
        syncEditorOutput(wrapperNode);
      });
      ensureEditorImagesInteractive(surface);

      surface.addEventListener("paste", async (event) => {
        const clipboardItems = event.clipboardData?.items ?? [];
        const imageItems = Array.from(clipboardItems).filter((item) => item.type.startsWith("image/"));
        if (imageItems.length === 0) return;

        event.preventDefault();
        pendingEditorUploads += imageItems.length;

        for (const imageItem of imageItems) {
          const file = imageItem.getAsFile();
          if (!file) {
            pendingEditorUploads -= 1;
            continue;
          }

          try {
            const slugInput = formNode.querySelector("input[name='slug']");
            const imageUrl = await uploadPastedImage(
              file,
              slugInput instanceof HTMLInputElement ? slugInput.value : "blog"
            );
            document.execCommand("insertImage", false, imageUrl);
            normalizeEditorImages(surface);
            ensureEditorImagesInteractive(surface);
            syncEditorOutput(wrapperNode);
          } catch (error) {
            window.alert(error instanceof Error ? error.message : "No pudimos subir la imagen.");
          } finally {
            pendingEditorUploads -= 1;
          }
        }
      });

      bindMouseImageResize(surface, wrapperNode);
      bindImageDragAndDrop(surface, wrapperNode);

      syncEditorOutput(wrapperNode);
      if (shouldPersistDraft) {
        formNode.addEventListener("input", saveDraftState);
        formNode.addEventListener("change", saveDraftState);
        document.addEventListener("visibilitychange", () => {
          if (document.visibilityState === "hidden") saveDraftState();
        });
      }
    });

    formNode.addEventListener("submit", (event) => {
      if (pendingEditorUploads > 0) {
        event.preventDefault();
        window.alert("Aun estamos subiendo imagenes del contenido. Espera unos segundos e intenta guardar nuevamente.");
        return;
      }
      editorWrappers.forEach((wrapperNode) => {
        if (wrapperNode instanceof HTMLElement) syncEditorOutput(wrapperNode);
      });
    });
  });
</script>
