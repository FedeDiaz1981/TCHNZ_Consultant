---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { getAdminDistributionContacts } from "../../lib/portal/admin";
import { getAdminFlash } from "../../lib/portal/admin-flash";
import { getModuleContentSection, getPortalModuleConfig } from "../../lib/portal/modules";

const user = Astro.locals.user;
const supabase = Astro.locals.supabase;
const portalModule = Astro.locals.portalModule;
const moduleConfig = getPortalModuleConfig(portalModule);
const contentSection = getModuleContentSection(portalModule);

if (!user || !supabase) {
  return Astro.redirect("/consultant/login");
}

if (!contentSection) {
  return Astro.redirect("/consultant/admin");
}

const flash = getAdminFlash(Astro.url);
const contacts = await getAdminDistributionContacts(supabase, portalModule);
const activeContactCount = contacts.filter((contact) => contact.isActive).length;

function formatDateTimeLabel(value: string | null) {
  if (!value) return "Sin fecha";

  return new Intl.DateTimeFormat("es-AR", {
    day: "2-digit",
    month: "short",
    year: "numeric",
    hour: "2-digit",
    minute: "2-digit"
  }).format(new Date(value));
}

const distributionContacts = contacts.map((contact) => {
  const searchValue = [
    contact.email,
    contact.displayName ?? "",
    contact.notes ?? "",
    contact.isActive ? "activo" : "inactivo"
  ]
    .join(" ")
    .toLowerCase();

  return {
    ...contact,
    searchValue
  };
});

const distributionData = {
  contacts: distributionContacts
};

const distributionDataJson = JSON.stringify(distributionData).replace(/</g, "\\u003c");
---

<AdminLayout
  title={`Correos | Administracion portal`}
  description={`Gestion de correos de distribucion para ${moduleConfig.name.es}`}
  userEmail={user.email ?? ""}
  activePath="/admin/correos"
  portalModule={portalModule}
>
  <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 sm:py-8">
    {flash && (
      <div
        class:list={[
          "mb-6 rounded-3xl border px-4 py-3.5 text-sm sm:px-5 sm:py-4",
          flash.tone === "error"
            ? "border-red-400/30 bg-red-500/10 text-red-50"
            : "border-emerald-400/30 bg-emerald-500/10 text-emerald-50"
        ]}
      >
        {flash.message}
      </div>
    )}

    <section class="space-y-6">
      <div class="portal-panel rounded-[30px] p-5 sm:p-6">
        <div class="flex flex-col gap-5 xl:flex-row xl:items-end xl:justify-between">
          <div class="max-w-3xl">
            <p class="portal-eyebrow text-[11px]">Distribucion por email</p>
            <h2 class="mt-2 text-2xl font-semibold text-white sm:text-3xl">Correos</h2>
            <p class="portal-copy mt-2 hidden text-sm leading-6 sm:block">
              Usa una tabla para verlos todos y un modal para crear o editar sin mezclar pantallas.
            </p>
          </div>

          <div class="flex flex-wrap gap-3 text-sm">
            <span class="rounded-full bg-emerald-500/15 px-3 py-2 text-emerald-100">
              {contacts.length} correos
            </span>
            <span class="rounded-full bg-white/10 px-3 py-2 text-white/70">
              {activeContactCount} activos
            </span>
          </div>
        </div>
      </div>

      <div class="portal-panel rounded-[30px] p-5 sm:p-6">
        <div class="flex flex-col gap-4 xl:flex-row xl:items-end xl:justify-between">
          <div class="max-w-3xl">
            <p class="portal-eyebrow text-[11px]">Gestor de correos</p>
            <h3 class="mt-2 text-xl font-semibold text-white sm:text-2xl">Listado y acciones</h3>
            <p class="portal-copy mt-2 text-sm leading-6">
              Crear y editar quedan en el modal. Eliminar sigue separado para que la accion quede clara.
            </p>
          </div>

          <div class="flex flex-col gap-3 sm:flex-row sm:items-center xl:min-w-0 xl:flex-1 xl:justify-end">
            <label class="admin-distribution-search">
              <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
              <input type="search" placeholder="Buscar correo" data-distribution-search />
            </label>

            <button
              type="button"
              class="distribution-icon-button distribution-icon-button--create distribution-create-button"
              data-open-distribution-dialog
              aria-label="Nuevo correo"
              title="Nuevo correo"
              onclick="window.openDistributionDialog && window.openDistributionDialog(null)"
            >
              <i class="fa-solid fa-plus" aria-hidden="true"></i>
              <span class="sr-only">Nuevo correo</span>
            </button>
          </div>
        </div>

        <div class="mt-4 flex flex-wrap gap-2" data-distribution-filters>
          <button type="button" class="distribution-filter is-active" data-distribution-filter="all">
            Todos
          </button>
          <button type="button" class="distribution-filter" data-distribution-filter="active">
            Activos
          </button>
          <button type="button" class="distribution-filter" data-distribution-filter="inactive">
            Inactivos
          </button>
        </div>

        <div class="mt-5 admin-distribution-table-wrap">
          <table class="admin-distribution-table">
            <thead>
              <tr>
                <th>Correo</th>
                <th>Estado</th>
                <th>Actualizada</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody>
              {distributionContacts.map((contact) => (
                <tr
                  data-distribution-row
                  data-status={contact.isActive ? "active" : "inactive"}
                  data-search-value={contact.searchValue}
                >
                  <td>
                    <div class="min-w-0">
                      <p class="truncate text-base font-semibold text-white">{contact.email}</p>
                      <p class="portal-copy mt-1 text-sm">
                        {contact.displayName ?? "Sin nombre visible"}
                      </p>
                    </div>
                  </td>

                  <td>
                    <span
                      class:list={[
                        "inline-flex rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.14em]",
                        contact.isActive
                          ? "bg-emerald-500/15 text-emerald-100"
                          : "bg-white/10 text-white/60"
                      ]}
                    >
                      {contact.isActive ? "Activo" : "Inactivo"}
                    </span>
                  </td>

                  <td>
                    <p class="text-sm text-white/85">{formatDateTimeLabel(contact.updatedAt)}</p>
                    <p class="portal-copy mt-1 text-xs">Ultimo cambio</p>
                  </td>

                  <td>
                    <div class="distribution-row-actions flex flex-wrap items-center gap-2">
                      <button
                        type="button"
                        class="distribution-icon-button distribution-icon-button--edit"
                        data-open-distribution-dialog
                        data-contact-id={contact.id}
                        aria-label={`Editar correo ${contact.email}`}
                        title={`Editar correo ${contact.email}`}
                        onclick="window.openDistributionDialog && window.openDistributionDialog(this.dataset.contactId || null)"
                      >
                        <i class="fa-solid fa-pen-to-square" aria-hidden="true"></i>
                        <span class="sr-only">Editar</span>
                      </button>

                      <form action="/consultant/api/admin/manage" method="POST">
                        <input type="hidden" name="action" value="delete-distribution-contact" />
                        <input type="hidden" name="redirect_to" value="/admin/correos" />
                        <input type="hidden" name="contact_id" value={contact.id} />
                        <button
                          type="submit"
                          class="distribution-icon-button distribution-icon-button--delete"
                          data-confirm-submit="Vas a eliminar este correo de distribucion. Esta accion no se puede deshacer. Deseas continuar?"
                          aria-label={`Eliminar correo ${contact.email}`}
                          title={`Eliminar correo ${contact.email}`}
                        >
                          <i class="fa-solid fa-trash-can" aria-hidden="true"></i>
                          <span class="sr-only">Eliminar</span>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div class="portal-empty-state mt-4 hidden rounded-[24px] px-4 py-5 text-sm" data-distribution-empty>
          No encontramos correos para ese criterio. Proba creando un nuevo correo.
        </div>
      </div>
    </section>
  </div>

  <dialog class="distribution-dialog" data-distribution-dialog>
    <div class="distribution-dialog__panel portal-panel rounded-[32px] p-0">
      <div class="distribution-dialog__header border-b border-white/10 px-5 py-4 sm:px-6">
        <div class="min-w-0">
          <p class="portal-eyebrow text-[11px]">Correos de distribucion</p>
          <h3 class="mt-2 text-2xl font-semibold text-white" data-distribution-dialog-title>
            Nuevo correo
          </h3>
          <p class="portal-copy mt-1 text-sm" data-distribution-dialog-subtitle>
            Crea un correo reutilizable para las listas de difusion.
          </p>
        </div>

        <button
          type="button"
          class="rounded-full border border-white/10 px-3 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-white/70 transition hover:border-white/20 hover:text-white"
          data-close-distribution-dialog
          onclick="window.closeDistributionDialog && window.closeDistributionDialog()"
        >
          Cerrar
        </button>
      </div>

      <div class="distribution-dialog__body px-5 py-5 sm:px-6">
        <div class="distribution-dialog__summary">
          <div class="distribution-dialog__summary-card">
            <span>Estado</span>
            <strong data-distribution-summary-status>Activo</strong>
          </div>
          <div class="distribution-dialog__summary-card">
            <span>Correos activos</span>
            <strong>{activeContactCount}</strong>
          </div>
          <div class="distribution-dialog__summary-card">
            <span>Total correos</span>
            <strong>{contacts.length}</strong>
          </div>
        </div>

        <div class="distribution-dialog__details-panel">
          <div class="flex items-center justify-between gap-3">
            <div>
              <p class="portal-eyebrow text-[11px]">Detalle</p>
              <h4 class="mt-2 text-lg font-semibold text-white">Correo seleccionado</h4>
            </div>
            <span class="rounded-full border border-white/10 px-3 py-2 text-xs font-semibold uppercase tracking-[0.14em] text-white/70">
              <span data-distribution-summary-members>0</span> cambios
            </span>
          </div>

          <div class="mt-4 grid gap-2" data-distribution-contact-detail>
            <span class="text-sm text-white/55">Selecciona un correo para ver su detalle.</span>
          </div>
        </div>

        <form
          action="/consultant/api/admin/manage"
          method="POST"
          class="distribution-dialog__form"
          data-distribution-form
        >
          <input type="hidden" name="action" value="create-distribution-contact" data-distribution-action />
          <input type="hidden" name="redirect_to" value="/admin/correos" />
          <input type="hidden" name="contact_id" value="" data-distribution-contact-id />

          <div class="grid gap-4 lg:grid-cols-2">
            <label class="block lg:col-span-2">
              <span class="mb-2 block text-sm font-medium text-white/80">Correo electronico</span>
              <input
                class="portal-input w-full rounded-2xl px-4 py-3"
                type="email"
                name="email"
                required
                data-distribution-email
              />
            </label>

            <label class="block lg:col-span-2">
              <span class="mb-2 block text-sm font-medium text-white/80">Nombre visible</span>
              <input
                class="portal-input w-full rounded-2xl px-4 py-3"
                type="text"
                name="display_name"
                placeholder="Equipo Comercial"
                data-distribution-display-name
              />
            </label>

            <label class="block lg:col-span-2">
              <span class="mb-2 block text-sm font-medium text-white/80">Notas</span>
              <textarea
                class="portal-input min-h-28 w-full rounded-2xl px-4 py-3"
                name="notes"
                placeholder="Observaciones internas"
                data-distribution-notes
              ></textarea>
            </label>

            <label class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white/80 lg:col-span-2">
              <input type="hidden" name="is_active" value="false" />
              <input
                type="checkbox"
                name="is_active"
                value="true"
                checked
                class="h-4 w-4"
                data-distribution-active
              />
              Correo activo
            </label>
          </div>

          <div class="flex flex-wrap items-center justify-end gap-3 border-t border-white/10 pt-4">
            <button
              type="button"
              class="portal-action-link border border-white/10 bg-white/5 text-white/80 hover:border-white/20 hover:bg-white/10"
              data-close-distribution-dialog
              onclick="window.closeDistributionDialog && window.closeDistributionDialog()"
            >
              Cancelar
            </button>
            <button
              type="submit"
              class="portal-action-link portal-action-link--solid"
              data-distribution-submit
            >
              Guardar correo
            </button>
          </div>
        </form>
      </div>
    </div>
  </dialog>
</AdminLayout>

<script type="application/json" id="distribution-data" set:html={distributionDataJson}></script>

<script>
  (() => {
    const dataNode = document.getElementById("distribution-data");
    if (!(dataNode instanceof HTMLScriptElement)) return;

    const data = JSON.parse(dataNode.textContent || "{}");
    const contacts = Array.isArray(data.contacts) ? data.contacts : [];

    const searchInput = document.querySelector("[data-distribution-search]");
    const filterButtons = Array.from(document.querySelectorAll("[data-distribution-filter]"));
    const rows = Array.from(document.querySelectorAll("[data-distribution-row]"));
    const emptyState = document.querySelector("[data-distribution-empty]");
    const openButtons = Array.from(document.querySelectorAll("[data-open-distribution-dialog]"));
    const closeButtons = Array.from(document.querySelectorAll("[data-close-distribution-dialog]"));

    const dialog = document.querySelector("[data-distribution-dialog]");
    const dialogForm = document.querySelector("[data-distribution-form]");
    const dialogTitle = document.querySelector("[data-distribution-dialog-title]");
    const dialogSubtitle = document.querySelector("[data-distribution-dialog-subtitle]");
    const dialogAction = document.querySelector("[data-distribution-action]");
    const dialogContactId = document.querySelector("[data-distribution-contact-id]");
    const dialogEmail = document.querySelector("[data-distribution-email]");
    const dialogDisplayName = document.querySelector("[data-distribution-display-name]");
    const dialogNotes = document.querySelector("[data-distribution-notes]");
    const dialogActive = document.querySelector("[data-distribution-active]");
    const summaryStatus = document.querySelector("[data-distribution-summary-status]");
    const summaryMembers = document.querySelector("[data-distribution-summary-members]");
    const contactDetail = document.querySelector("[data-distribution-contact-detail]");

    const state = {
      query: "",
      filter: "all",
      contactId: null
    };

    function getContact(contactId) {
      return contacts.find((contact) => contact.id === contactId) ?? null;
    }

    function updateDetailPanel(contact) {
      if (!(contactDetail instanceof HTMLElement)) return;

      contactDetail.replaceChildren();

      if (!contact) {
        const empty = document.createElement("span");
        empty.className = "text-sm text-white/55";
        empty.textContent = "Selecciona un correo para ver su detalle.";
        contactDetail.appendChild(empty);
        return;
      }

      const email = document.createElement("div");
      email.className = "rounded-2xl border border-white/10 bg-black/20 px-4 py-3";
      email.innerHTML = `<p class="portal-copy text-xs uppercase tracking-[0.14em]">Correo</p><strong class="mt-1 block text-sm text-white">${contact.email}</strong>`;
      contactDetail.appendChild(email);

      const displayName = document.createElement("div");
      displayName.className = "rounded-2xl border border-white/10 bg-black/20 px-4 py-3";
      displayName.innerHTML = `<p class="portal-copy text-xs uppercase tracking-[0.14em]">Nombre visible</p><strong class="mt-1 block text-sm text-white">${contact.displayName || "Sin nombre visible"}</strong>`;
      contactDetail.appendChild(displayName);

      const notes = document.createElement("div");
      notes.className = "rounded-2xl border border-white/10 bg-black/20 px-4 py-3";
      notes.innerHTML = `<p class="portal-copy text-xs uppercase tracking-[0.14em]">Notas</p><strong class="mt-1 block truncate text-sm text-white">${contact.notes || "Sin notas"}</strong>`;
      contactDetail.appendChild(notes);
    }

    function syncDialogForCreate() {
      if (!(dialogForm instanceof HTMLFormElement)) return;

      dialogForm.reset();

      if (dialogAction instanceof HTMLInputElement) dialogAction.value = "create-distribution-contact";
      if (dialogContactId instanceof HTMLInputElement) dialogContactId.value = "";
      if (dialogTitle instanceof HTMLElement) dialogTitle.textContent = "Nuevo correo";
      if (dialogSubtitle instanceof HTMLElement) {
        dialogSubtitle.textContent = "Crea un correo reutilizable para las listas de difusion.";
      }
      if (dialogEmail instanceof HTMLInputElement) dialogEmail.value = "";
      if (dialogDisplayName instanceof HTMLInputElement) dialogDisplayName.value = "";
      if (dialogNotes instanceof HTMLTextAreaElement) dialogNotes.value = "";
      if (dialogActive instanceof HTMLInputElement) dialogActive.checked = true;
      if (summaryStatus instanceof HTMLElement) summaryStatus.textContent = "Activo";
      if (summaryMembers instanceof HTMLElement) summaryMembers.textContent = "0";

      updateDetailPanel(null);
    }

    function syncDialogForEdit(contact) {
      if (!(dialogForm instanceof HTMLFormElement)) return;

      dialogForm.reset();

      if (dialogAction instanceof HTMLInputElement) dialogAction.value = "update-distribution-contact";
      if (dialogContactId instanceof HTMLInputElement) dialogContactId.value = contact.id;
      if (dialogTitle instanceof HTMLElement) dialogTitle.textContent = contact.email;
      if (dialogSubtitle instanceof HTMLElement) {
        dialogSubtitle.textContent = contact.displayName || "Edita email, nombre visible, notas y estado.";
      }
      if (dialogEmail instanceof HTMLInputElement) dialogEmail.value = contact.email;
      if (dialogDisplayName instanceof HTMLInputElement) dialogDisplayName.value = contact.displayName ?? "";
      if (dialogNotes instanceof HTMLTextAreaElement) dialogNotes.value = contact.notes ?? "";
      if (dialogActive instanceof HTMLInputElement) dialogActive.checked = contact.isActive;
      if (summaryStatus instanceof HTMLElement) summaryStatus.textContent = contact.isActive ? "Activo" : "Inactivo";
      if (summaryMembers instanceof HTMLElement) summaryMembers.textContent = "1";

      updateDetailPanel(contact);
    }

    function openDialog(contactId = null) {
      if (!(dialog instanceof HTMLDialogElement)) return;

      const contact = contactId ? getContact(contactId) : null;
      if (contactId && !contact) return;

      state.contactId = contactId;

      if (contact) {
        syncDialogForEdit(contact);
      } else {
        syncDialogForCreate();
      }

      document.body.classList.add("distribution-dialog-open");
      document.documentElement.classList.add("distribution-dialog-open");
      dialog.showModal();

      if (dialogEmail instanceof HTMLInputElement) {
        dialogEmail.focus();
      }
    }

    window.openDistributionDialog = openDialog;

    function closeDialog() {
      if (dialog instanceof HTMLDialogElement && dialog.open) {
        dialog.close();
      }
    }

    window.closeDistributionDialog = closeDialog;

    function setActiveFilter(filter) {
      state.filter = filter;

      filterButtons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        button.classList.toggle("is-active", button.dataset.distributionFilter === filter);
      });

      applyFilters();
    }

    function applyFilters() {
      const query = state.query;
      let visibleCount = 0;

      rows.forEach((row) => {
        if (!(row instanceof HTMLElement)) return;

        const value = row.dataset.searchValue || "";
        const status = row.dataset.status || "all";
        const matchesQuery = !query || value.includes(query);
        const matchesStatus = state.filter === "all" || state.filter === status;
        const isVisible = matchesQuery && matchesStatus;

        row.style.display = isVisible ? "" : "none";
        if (isVisible) visibleCount += 1;
      });

      if (emptyState instanceof HTMLElement) {
        emptyState.classList.toggle("hidden", visibleCount > 0);
      }
    }

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;

      const confirmSubmitTrigger = target.closest("[data-confirm-submit]");
      if (confirmSubmitTrigger instanceof HTMLButtonElement) {
        const message = confirmSubmitTrigger.dataset.confirmSubmit;
        if (message && !window.confirm(message)) {
          event.preventDefault();
        }
      }
    });

    openButtons.forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;

      button.addEventListener("click", () => {
        openDialog(button.dataset.contactId || null);
      });
    });

    closeButtons.forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;

      button.addEventListener("click", () => {
        closeDialog();
      });
    });

    document.addEventListener("input", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement)) return;

      if (target.matches("[data-distribution-search]")) {
        state.query = target.value.trim().toLowerCase();
        applyFilters();
      }
    });

    document.addEventListener("change", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement)) return;

      if (target === dialogActive) {
        if (summaryStatus instanceof HTMLElement) {
          summaryStatus.textContent = dialogActive instanceof HTMLInputElement && dialogActive.checked ? "Activo" : "Inactivo";
        }
      }
    });

    if (dialog instanceof HTMLDialogElement) {
      dialog.addEventListener("cancel", () => {
        closeDialog();
      });

      dialog.addEventListener("close", () => {
        document.body.classList.remove("distribution-dialog-open");
        document.documentElement.classList.remove("distribution-dialog-open");
        state.contactId = null;

        if (dialogForm instanceof HTMLFormElement) {
          dialogForm.reset();
        }

        if (dialogTitle instanceof HTMLElement) dialogTitle.textContent = "Nuevo correo";
        if (dialogSubtitle instanceof HTMLElement) {
          dialogSubtitle.textContent = "Crea un correo reutilizable para las listas de difusion.";
        }

        updateDetailPanel(null);
      });

      dialog.addEventListener("click", (event) => {
        if (event.target === dialog) {
          closeDialog();
        }
      });
    }

    setActiveFilter("all");
    applyFilters();
    updateDetailPanel(null);
  })();
</script>

<style>
  .admin-distribution-search {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1 1 360px;
    min-width: 0;
    max-width: 360px;
    padding: 0.95rem 1rem;
    border-radius: 1.1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.04);
  }

  .admin-distribution-search i {
    color: rgba(255, 255, 255, 0.5);
  }

  .admin-distribution-search input {
    width: 100%;
    border: 0;
    outline: 0;
    background: transparent;
    color: #fff;
    font: inherit;
  }

  .admin-distribution-search input::placeholder {
    color: rgba(255, 255, 255, 0.42);
  }

  .distribution-filter {
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.04);
    color: rgba(255, 255, 255, 0.78);
    border-radius: 999px;
    padding: 0.58rem 0.9rem;
    font: inherit;
    font-size: 0.88rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .distribution-filter:hover {
    border-color: rgba(239, 124, 14, 0.36);
    background: rgba(239, 124, 14, 0.08);
    color: #fff;
  }

  .distribution-filter.is-active {
    border-color: rgba(239, 124, 14, 0.72);
    background: rgba(239, 124, 14, 0.16);
    color: #fff;
    box-shadow: inset 0 0 0 1px rgba(239, 124, 14, 0.16);
  }

  .distribution-create-button {
    width: 2.95rem;
    height: 2.95rem;
    min-height: 2.95rem;
    flex: none;
    padding: 0;
    border-radius: 0.95rem;
    align-self: center;
    white-space: nowrap;
  }

  .distribution-row-actions {
    min-height: 100%;
    align-content: center;
  }

  .distribution-icon-button {
    width: 2.55rem;
    height: 2.55rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.9rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.04);
    color: rgba(255, 255, 255, 0.84);
    transition: transform 0.18s ease, background-color 0.18s ease, border-color 0.18s ease, color 0.18s ease;
  }

  .distribution-icon-button:hover {
