---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { getAdminDistributionContacts, getAdminDistributionLists } from "../../lib/portal/admin";
import { getAdminFlash } from "../../lib/portal/admin-flash";
import { getModuleContentSection, getPortalModuleConfig } from "../../lib/portal/modules";

const user = Astro.locals.user;
const supabase = Astro.locals.supabase;
const portalModule = Astro.locals.portalModule;
const moduleConfig = getPortalModuleConfig(portalModule);
const contentSection = getModuleContentSection(portalModule);

if (!user || !supabase) {
  return Astro.redirect("/consultant/login");
}

if (!contentSection) {
  return Astro.redirect("/consultant/admin");
}

const flash = getAdminFlash(Astro.url);
const [lists, contacts] = await Promise.all([
  getAdminDistributionLists(supabase, portalModule),
  getAdminDistributionContacts(supabase, portalModule)
]);

const contactsById = new Map(contacts.map((contact) => [contact.id, contact]));
const activeListCount = lists.filter((list) => list.isActive).length;

function formatDateTimeLabel(value: string | null) {
  if (!value) return "Sin fecha";

  return new Intl.DateTimeFormat("es-AR", {
    day: "2-digit",
    month: "short",
    year: "numeric",
    hour: "2-digit",
    minute: "2-digit"
  }).format(new Date(value));
}

const distributionLists = lists.map((list) => {
  const memberEmails = list.memberIds
    .map((memberId) => contactsById.get(memberId)?.email ?? "")
    .filter(Boolean);

  const searchValue = [
    list.name,
    list.description ?? "",
    list.isActive ? "activa" : "inactiva",
    String(list.memberCount),
    ...list.memberIds.map((memberId) => contactsById.get(memberId)?.email ?? ""),
    ...list.memberIds.map((memberId) => contactsById.get(memberId)?.displayName ?? "")
  ]
    .join(" ")
    .toLowerCase();

  return {
    ...list,
    memberEmails,
    searchValue
  };
});

const distributionData = {
  lists: distributionLists,
  contacts: contacts.map((contact) => ({
    id: contact.id,
    label: contact.displayName ? `${contact.displayName} · ${contact.email}` : contact.email,
    email: contact.email,
    displayName: contact.displayName ?? "",
    searchValue: `${contact.email} ${contact.displayName ?? ""}`.toLowerCase()
  }))
};

const distributionDataJson = JSON.stringify(distributionData).replace(/</g, "\\u003c");
---

<AdminLayout
  title={`Listas de difusion | Administracion portal`}
  description={`Gestion de listas de difusion para ${moduleConfig.name.es}`}
  userEmail={user.email ?? ""}
  activePath="/admin/listas-difusion"
  portalModule={portalModule}
>
  <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 sm:py-8">
    {flash && (
      <div
        class:list={[
          "mb-6 rounded-3xl border px-4 py-3.5 text-sm sm:px-5 sm:py-4",
          flash.tone === "error"
            ? "border-red-400/30 bg-red-500/10 text-red-50"
            : "border-emerald-400/30 bg-emerald-500/10 text-emerald-50"
        ]}
      >
        {flash.message}
      </div>
    )}

    <section class="space-y-6">
      <div class="portal-panel rounded-[30px] p-5 sm:p-6">
        <div class="flex flex-col gap-5 xl:flex-row xl:items-end xl:justify-between">
          <div class="max-w-3xl">
            <p class="portal-eyebrow text-[11px]">Administracion interna</p>
            <h2 class="mt-2 text-2xl font-semibold text-white sm:text-3xl">Listas de difusion</h2>
            <p class="portal-copy mt-2 hidden text-sm leading-6 sm:block">
              Usa una tabla para verlas todas y un modal para crear o editar sin mezclar pantallas.
            </p>
          </div>

          <div class="flex flex-wrap gap-3 text-sm">
            <span class="rounded-full bg-emerald-500/15 px-3 py-2 text-emerald-100">
              {lists.length} listas
            </span>
            <span class="rounded-full bg-white/10 px-3 py-2 text-white/70">
              {activeListCount} activas
            </span>
            <span class="rounded-full bg-white/10 px-3 py-2 text-white/70">
              {contacts.length} contactos
            </span>
          </div>
        </div>
      </div>

      <div class="portal-panel rounded-[30px] p-5 sm:p-6">
        <div class="flex flex-col gap-4 xl:flex-row xl:items-end xl:justify-between">
          <div class="max-w-3xl">
            <p class="portal-eyebrow text-[11px]">Gestor de listas</p>
            <h3 class="mt-2 text-xl font-semibold text-white sm:text-2xl">Listado y acciones</h3>
            <p class="portal-copy mt-2 text-sm leading-6">
              Editar y crear ocurren en un solo modal. Eliminar sigue separado para que la accion
              quede clara.
            </p>
          </div>

          <div class="flex flex-col gap-3 sm:flex-row sm:items-center xl:min-w-0 xl:flex-1 xl:justify-end">
            <label class="admin-distribution-search">
              <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
              <input type="search" placeholder="Buscar lista" data-distribution-search />
            </label>

            <button
              type="button"
              class="distribution-icon-button distribution-icon-button--create distribution-create-button"
              data-open-distribution-dialog
              aria-label="Nueva lista"
              title="Nueva lista"
              onclick="window.openDistributionDialog && window.openDistributionDialog(null)"
            >
              <i class="fa-solid fa-plus" aria-hidden="true"></i>
              <span class="sr-only">Nueva lista</span>
            </button>
          </div>
        </div>

        <div class="mt-4 flex flex-wrap gap-2" data-distribution-filters>
          <button
            type="button"
            class="distribution-filter is-active"
            data-distribution-filter="all"
          >
            Todas
          </button>
          <button type="button" class="distribution-filter" data-distribution-filter="active">
            Activas
          </button>
          <button type="button" class="distribution-filter" data-distribution-filter="inactive">
            Inactivas
          </button>
        </div>

        <div class="mt-5 admin-distribution-table-wrap">
          <table class="admin-distribution-table">
            <thead>
              <tr>
                <th>Lista</th>
                <th>Estado</th>
                <th>Actualizada</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody>
              {distributionLists.map((list) => (
                <tr
                  data-distribution-row
                  data-status={list.isActive ? "active" : "inactive"}
                  data-search-value={list.searchValue}
                  >
                  <td>
                    <div class="min-w-0">
                      <p class="truncate text-base font-semibold text-white">{list.name}</p>
                    </div>
                  </td>

                  <td>
                    <span
                      class:list={[
                        "inline-flex rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.14em]",
                        list.isActive
                          ? "bg-emerald-500/15 text-emerald-100"
                          : "bg-white/10 text-white/60"
                      ]}
                    >
                      {list.isActive ? "Activa" : "Inactiva"}
                    </span>
                  </td>

                  <td>
                    <p class="text-sm text-white/85">{formatDateTimeLabel(list.updatedAt)}</p>
                    <p class="portal-copy mt-1 text-xs">Ultimo cambio</p>
                  </td>

                  <td>
                    <div class="distribution-row-actions flex flex-wrap items-center gap-2">
                      <button
                        type="button"
                        class="distribution-icon-button distribution-icon-button--edit"
                        data-open-distribution-dialog
                        data-list-id={list.id}
                        aria-label={`Editar lista ${list.name}`}
                        title={`Editar lista ${list.name}`}
                        onclick="window.openDistributionDialog && window.openDistributionDialog(this.dataset.listId || null)"
                      >
                        <i class="fa-solid fa-pen-to-square" aria-hidden="true"></i>
                        <span class="sr-only">Editar</span>
                      </button>

                      <form action="/consultant/api/admin/manage" method="POST">
                        <input type="hidden" name="action" value="delete-distribution-list" />
                        <input type="hidden" name="redirect_to" value="/admin/listas-difusion" />
                        <input type="hidden" name="list_id" value={list.id} />
                        <button
                          type="submit"
                          class="distribution-icon-button distribution-icon-button--delete"
                          data-confirm-submit="Vas a eliminar esta lista de difusion. Esta accion no se puede deshacer. Deseas continuar?"
                          aria-label={`Eliminar lista ${list.name}`}
                          title={`Eliminar lista ${list.name}`}
                        >
                          <i class="fa-solid fa-trash-can" aria-hidden="true"></i>
                          <span class="sr-only">Eliminar</span>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div class="portal-empty-state mt-4 hidden rounded-[24px] px-4 py-5 text-sm" data-distribution-empty>
          No encontramos listas para ese criterio. Proba creando una nueva lista.
        </div>
      </div>
    </section>
  </div>

  <dialog class="distribution-dialog" data-distribution-dialog>
    <div class="distribution-dialog__panel portal-panel rounded-[32px] p-0">
      <div class="distribution-dialog__header border-b border-white/10 px-5 py-4 sm:px-6">
        <div class="min-w-0">
          <p class="portal-eyebrow text-[11px]">Listas de difusion</p>
          <h3 class="mt-2 text-2xl font-semibold text-white" data-distribution-dialog-title>
            Nueva lista
          </h3>
          <p class="portal-copy mt-1 text-sm" data-distribution-dialog-subtitle>
            Crea una nueva lista reutilizable para agrupar correos.
          </p>
        </div>

          <button
          type="button"
          class="rounded-full border border-white/10 px-3 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-white/70 transition hover:border-white/20 hover:text-white"
          data-close-distribution-dialog
          onclick="window.closeDistributionDialog && window.closeDistributionDialog()"
        >
          Cerrar
        </button>
      </div>

      <div class="distribution-dialog__body px-5 py-5 sm:px-6">
        <div class="distribution-dialog__summary">
          <div class="distribution-dialog__summary-card">
            <span>Miembros seleccionados</span>
            <strong data-distribution-summary-members>0</strong>
          </div>
          <div class="distribution-dialog__summary-card">
            <span>Contactos disponibles</span>
            <strong>{contacts.length}</strong>
          </div>
          <div class="distribution-dialog__summary-card">
            <span>Estado</span>
            <strong data-distribution-summary-status>Activa</strong>
          </div>
        </div>

        <div class="distribution-dialog__members-panel">
          <div class="flex items-center justify-between gap-3">
            <div>
              <p class="portal-eyebrow text-[11px]">Detalle de correos</p>
              <h4 class="mt-2 text-lg font-semibold text-white">Miembros incluidos</h4>
            </div>
            <span class="rounded-full border border-white/10 px-3 py-2 text-xs font-semibold uppercase tracking-[0.14em] text-white/70">
              <span data-distribution-member-count>0</span> correos
            </span>
          </div>

          <div class="mt-4 flex flex-wrap gap-2" data-distribution-member-chips>
            <span class="text-sm text-white/55">Selecciona una lista para ver sus correos.</span>
          </div>
        </div>

        <form
          action="/consultant/api/admin/manage"
          method="POST"
          class="distribution-dialog__form"
          data-distribution-form
        >
          <input type="hidden" name="action" value="create-distribution-list" data-distribution-action />
          <input type="hidden" name="redirect_to" value="/admin/listas-difusion" />
          <input type="hidden" name="list_id" value="" data-distribution-list-id />

          <div class="grid gap-4 lg:grid-cols-2">
            <label class="block">
              <span class="mb-2 block text-sm font-medium text-white/80">Nombre</span>
              <input
                class="portal-input w-full rounded-2xl px-4 py-3"
                type="text"
                name="name"
                required
                data-distribution-name
              />
            </label>

            <label class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white/80">
              <input type="hidden" name="is_active" value="false" />
              <input
                type="checkbox"
                name="is_active"
                value="true"
                checked
                class="h-4 w-4"
                data-distribution-active
              />
              Lista activa
            </label>

            <label class="block lg:col-span-2">
              <span class="mb-2 block text-sm font-medium text-white/80">Descripcion</span>
              <textarea
                class="portal-input min-h-28 w-full rounded-2xl px-4 py-3"
                name="description"
                placeholder="Uso interno de la lista"
                data-distribution-description
              ></textarea>
            </label>

            <div class="block lg:col-span-2">
              <span class="mb-2 block text-sm font-medium text-white/80">Miembros</span>
              <label class="distribution-member-search">
                <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                <input
                  type="search"
                  placeholder="Buscar correos o nombres"
                  data-distribution-member-search
                />
              </label>
              <div class="distribution-member-picker" data-distribution-member-picker>
                {contacts.map((contact) => (
                  <label
                    class="distribution-member-option"
                    data-member-search-value={`${contact.email} ${contact.displayName ?? ""}`.toLowerCase()}
                  >
                    <input
                      type="checkbox"
                      name="member_ids"
                      value={contact.id}
                      data-distribution-member-checkbox
                      data-member-display-name={contact.displayName ?? ""}
                    />
                    <span class="distribution-member-option__copy">
                      <strong>{contact.displayName || "Sin nombre visible"}</strong>
                    </span>
                  </label>
                ))}
              </div>
              <p class="portal-copy mt-2 text-xs">
                Selecciona uno o varios correos para incluirlos en la lista.
              </p>
            </div>
          </div>

          <div class="flex flex-wrap items-center justify-end gap-3 border-t border-white/10 pt-4">
            <button
              type="button"
              class="portal-action-link border border-white/10 bg-white/5 text-white/80 hover:border-white/20 hover:bg-white/10"
              data-close-distribution-dialog
              onclick="window.closeDistributionDialog && window.closeDistributionDialog()"
            >
              Cancelar
            </button>
            <button
              type="submit"
              class="portal-action-link portal-action-link--solid"
              data-distribution-submit
            >
              Guardar lista
            </button>
          </div>
        </form>
      </div>
    </div>
  </dialog>
</AdminLayout>

<script type="application/json" id="distribution-data" set:html={distributionDataJson}></script>

<script>
  (() => {
    const dataNode = document.getElementById("distribution-data");
    if (!(dataNode instanceof HTMLScriptElement)) return;

    const data = JSON.parse(dataNode.textContent || "{}");
    const lists = Array.isArray(data.lists) ? data.lists : [];

    const searchInput = document.querySelector("[data-distribution-search]");
    const filterButtons = Array.from(document.querySelectorAll("[data-distribution-filter]"));
    const rows = Array.from(document.querySelectorAll("[data-distribution-row]"));
    const emptyState = document.querySelector("[data-distribution-empty]");
    const openButtons = Array.from(document.querySelectorAll("[data-open-distribution-dialog]"));
    const closeButtons = Array.from(document.querySelectorAll("[data-close-distribution-dialog]"));

    const dialog = document.querySelector("[data-distribution-dialog]");
    const dialogForm = document.querySelector("[data-distribution-form]");
    const dialogTitle = document.querySelector("[data-distribution-dialog-title]");
    const dialogSubtitle = document.querySelector("[data-distribution-dialog-subtitle]");
    const dialogAction = document.querySelector("[data-distribution-action]");
    const dialogListId = document.querySelector("[data-distribution-list-id]");
      const dialogName = document.querySelector("[data-distribution-name]");
      const dialogDescription = document.querySelector("[data-distribution-description]");
      const dialogActive = document.querySelector("[data-distribution-active]");
      const dialogMemberSearch = document.querySelector("[data-distribution-member-search]");
      const dialogMemberPicker = document.querySelector("[data-distribution-member-picker]");
      const dialogMemberCheckboxes = Array.from(document.querySelectorAll("[data-distribution-member-checkbox]"));
      const summaryMembers = document.querySelector("[data-distribution-summary-members]");
      const summaryStatus = document.querySelector("[data-distribution-summary-status]");
      const memberCount = document.querySelector("[data-distribution-member-count]");
      const memberChips = document.querySelector("[data-distribution-member-chips]");

    const state = {
      query: "",
      filter: "all",
      listId: null
    };

    function getList(listId) {
      return lists.find((list) => list.id === listId) ?? null;
    }

    function setSelectedMembers(memberIds) {
      if (dialogMemberCheckboxes.length === 0) return;

      const selectedIds = new Set(memberIds);
      dialogMemberCheckboxes.forEach((checkbox) => {
        if (!(checkbox instanceof HTMLInputElement)) return;
        checkbox.checked = selectedIds.has(checkbox.value);
      });
    }

    function clearSelectedMembers() {
      if (dialogMemberCheckboxes.length === 0) return;

      dialogMemberCheckboxes.forEach((checkbox) => {
        if (!(checkbox instanceof HTMLInputElement)) return;
        checkbox.checked = false;
      });
    }

    function updateDialogSummary() {
      const selectedCheckboxes = dialogMemberCheckboxes.filter((checkbox) => checkbox instanceof HTMLInputElement && checkbox.checked);

      if (summaryMembers instanceof HTMLElement) {
        summaryMembers.textContent = String(selectedCheckboxes.length);
      }

      if (summaryStatus instanceof HTMLElement && dialogActive instanceof HTMLInputElement) {
        summaryStatus.textContent = dialogActive.checked ? "Activa" : "Inactiva";
      }

      if (memberCount instanceof HTMLElement) {
        memberCount.textContent = String(selectedCheckboxes.length);
      }

      if (memberChips instanceof HTMLElement) {
        const selectedLabels = selectedCheckboxes.map((checkbox) => {
          const displayName = checkbox.dataset.memberDisplayName?.trim() || "";
          return displayName || "Sin nombre visible";
        });
        memberChips.replaceChildren();

        if (selectedLabels.length === 0) {
          const empty = document.createElement("span");
          empty.className = "text-sm text-white/55";
          empty.textContent = "Sin correos seleccionados.";
          memberChips.appendChild(empty);
          return;
        }

        selectedLabels.forEach((label) => {
          const chip = document.createElement("span");
          chip.className = "rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-white/80";
          chip.textContent = label;
          memberChips.appendChild(chip);
        });
      }
    }

    function applyMemberFilter() {
      const query = dialogMemberSearch instanceof HTMLInputElement ? dialogMemberSearch.value.trim().toLowerCase() : "";

      if (!(dialogMemberPicker instanceof HTMLElement)) return;

      dialogMemberPicker.querySelectorAll("[data-member-search-value]").forEach((option) => {
        if (!(option instanceof HTMLElement)) return;

        const value = option.dataset.memberSearchValue || "";
        option.style.display = !query || value.includes(query) ? "" : "none";
      });
    }

    function syncDialogForCreate() {
      if (!(dialogForm instanceof HTMLFormElement)) return;

      dialogForm.reset();

      if (dialogAction instanceof HTMLInputElement) dialogAction.value = "create-distribution-list";
      if (dialogListId instanceof HTMLInputElement) dialogListId.value = "";
      if (dialogTitle instanceof HTMLElement) dialogTitle.textContent = "Nueva lista";
      if (dialogSubtitle instanceof HTMLElement) {
        dialogSubtitle.textContent = "Crea una lista reutilizable para agrupar correos.";
      }
      if (dialogName instanceof HTMLInputElement) dialogName.value = "";
      if (dialogDescription instanceof HTMLTextAreaElement) dialogDescription.value = "";
      if (dialogActive instanceof HTMLInputElement) dialogActive.checked = true;
      if (dialogMemberSearch instanceof HTMLInputElement) dialogMemberSearch.value = "";

      clearSelectedMembers();
      applyMemberFilter();
      updateDialogSummary();
    }

    function syncDialogForEdit(list) {
      if (!(dialogForm instanceof HTMLFormElement)) return;

      dialogForm.reset();

      if (dialogAction instanceof HTMLInputElement) dialogAction.value = "update-distribution-list";
      if (dialogListId instanceof HTMLInputElement) dialogListId.value = list.id;
      if (dialogTitle instanceof HTMLElement) dialogTitle.textContent = list.name;
      if (dialogSubtitle instanceof HTMLElement) {
        dialogSubtitle.textContent = list.description || "Edita el nombre, el estado y los miembros.";
      }
      if (dialogName instanceof HTMLInputElement) dialogName.value = list.name;
      if (dialogDescription instanceof HTMLTextAreaElement) dialogDescription.value = list.description ?? "";
      if (dialogActive instanceof HTMLInputElement) dialogActive.checked = list.isActive;
      if (dialogMemberSearch instanceof HTMLInputElement) dialogMemberSearch.value = "";

      setSelectedMembers(list.memberIds);
      applyMemberFilter();
      updateDialogSummary();
    }

    function openDialog(listId = null) {
      if (!(dialog instanceof HTMLDialogElement)) return;

      const list = listId ? getList(listId) : null;
      if (listId && !list) return;

      state.listId = listId;

      if (list) {
        syncDialogForEdit(list);
      } else {
        syncDialogForCreate();
      }

      document.body.classList.add("distribution-dialog-open");
      document.documentElement.classList.add("distribution-dialog-open");
      dialog.showModal();

      if (dialogName instanceof HTMLInputElement) {
        dialogName.focus();
      }
    }

    window.openDistributionDialog = openDialog;

    function closeDialog() {
      if (dialog instanceof HTMLDialogElement && dialog.open) {
        dialog.close();
      }
    }

    window.closeDistributionDialog = closeDialog;

    function setActiveFilter(filter) {
      state.filter = filter;

      filterButtons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        button.classList.toggle("is-active", button.dataset.distributionFilter === filter);
      });

      applyFilters();
    }

    function applyFilters() {
      const query = state.query;
      let visibleCount = 0;

      rows.forEach((row) => {
        if (!(row instanceof HTMLElement)) return;

        const value = row.dataset.searchValue || "";
        const status = row.dataset.status || "all";
        const matchesQuery = !query || value.includes(query);
        const matchesStatus = state.filter === "all" || state.filter === status;
        const isVisible = matchesQuery && matchesStatus;

        row.style.display = isVisible ? "" : "none";
        if (isVisible) visibleCount += 1;
      });

      if (emptyState instanceof HTMLElement) {
        emptyState.classList.toggle("hidden", visibleCount > 0);
      }
    }

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;

      const confirmSubmitTrigger = target.closest("[data-confirm-submit]");
      if (confirmSubmitTrigger instanceof HTMLButtonElement) {
        const message = confirmSubmitTrigger.dataset.confirmSubmit;
        if (message && !window.confirm(message)) {
          event.preventDefault();
        }
      }
    });

    openButtons.forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;

      button.addEventListener("click", () => {
        openDialog(button.dataset.listId || null);
      });
    });

    closeButtons.forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;

      button.addEventListener("click", () => {
        closeDialog();
      });
    });

    document.addEventListener("input", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement)) return;

      if (target.matches("[data-distribution-search]")) {
        state.query = target.value.trim().toLowerCase();
        applyFilters();
      }
    });

    document.addEventListener("change", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement)) return;

      if (target === dialogActive || target.matches("[data-distribution-member-checkbox]")) {
        updateDialogSummary();
      }
    });

    document.addEventListener("input", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement)) return;

      if (target.matches("[data-distribution-member-search]")) {
        applyMemberFilter();
      }
    });

    if (dialog instanceof HTMLDialogElement) {
      dialog.addEventListener("cancel", () => {
        closeDialog();
      });

      dialog.addEventListener("close", () => {
        document.body.classList.remove("distribution-dialog-open");
        document.documentElement.classList.remove("distribution-dialog-open");
        state.listId = null;

        if (dialogForm instanceof HTMLFormElement) {
          dialogForm.reset();
        }

        if (dialogTitle instanceof HTMLElement) dialogTitle.textContent = "Nueva lista";
        if (dialogSubtitle instanceof HTMLElement) {
          dialogSubtitle.textContent = "Crea una lista reutilizable para agrupar correos.";
        }

        clearSelectedMembers();
        updateDialogSummary();
      });

      dialog.addEventListener("click", (event) => {
        if (event.target === dialog) {
          closeDialog();
        }
      });
    }

    setActiveFilter("all");
    applyFilters();
    updateDialogSummary();
  })();
</script>

