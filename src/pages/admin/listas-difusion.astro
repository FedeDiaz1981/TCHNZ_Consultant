---
import AdminLayout from "../../layouts/AdminLayout.astro";
import {
  getAdminDistributionContacts,
  getAdminDistributionLists,
} from "../../lib/portal/admin";
import { getAdminFlash } from "../../lib/portal/admin-flash";
import { getModuleContentSection, getPortalModuleConfig } from "../../lib/portal/modules";

const user = Astro.locals.user;
const supabase = Astro.locals.supabase;
const portalModule = Astro.locals.portalModule;
const moduleConfig = getPortalModuleConfig(portalModule);
const contentSection = getModuleContentSection(portalModule);

if (!user || !supabase) {
  return Astro.redirect("/consultant/login");
}

if (!contentSection) {
  return Astro.redirect("/consultant/admin");
}

const flash = getAdminFlash(Astro.url);
const [lists, contacts] = await Promise.all([
  getAdminDistributionLists(supabase, portalModule),
  getAdminDistributionContacts(supabase, portalModule)
]);

const contactsById = new Map(contacts.map((contact) => [contact.id, contact]));

function formatDateTimeLabel(value: string | null) {
  if (!value) return "Sin fecha";

  return new Intl.DateTimeFormat("es-AR", {
    day: "2-digit",
    month: "short",
    year: "numeric",
    hour: "2-digit",
    minute: "2-digit"
  }).format(new Date(value));
}
---

<AdminLayout
  title={`Listas de difusion | Administracion portal`}
  description={`Gestion de listas de difusion para ${moduleConfig.name.es}`}
  userEmail={user.email ?? ""}
  activePath="/admin/listas-difusion"
  portalModule={portalModule}
>
  <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 sm:py-8">
    {flash && (
      <div
        class:list={[
          "mb-6 rounded-3xl border px-4 py-3.5 text-sm sm:px-5 sm:py-4",
          flash.tone === "error"
            ? "border-red-400/30 bg-red-500/10 text-red-50"
            : "border-emerald-400/30 bg-emerald-500/10 text-emerald-50"
        ]}
      >
        {flash.message}
      </div>
    )}

    <section class="space-y-6">
      <div class="portal-panel rounded-[30px] p-5 sm:p-6">
        <div class="flex flex-col gap-5 xl:flex-row xl:items-end xl:justify-between">
          <div class="max-w-3xl">
            <p class="portal-eyebrow text-[11px]">Distribucion por email</p>
            <h2 class="mt-2 text-2xl font-semibold text-white sm:text-3xl">Listas de difusión</h2>
            <p class="portal-copy mt-2 hidden text-sm leading-6 sm:block">
              Agrupa correos cargados en listas reutilizables para enviar los articulos de training.
            </p>
          </div>

          <div class="flex flex-wrap items-center gap-3">
            <span class="self-start rounded-full border border-white/10 px-3 py-2 text-xs font-semibold uppercase tracking-[0.14em] text-white/70 sm:self-auto">
              {lists.length} listas
            </span>
          </div>
        </div>
      </div>

      <div class="grid gap-6 xl:grid-cols-[1fr_1.15fr]">
        <article class="portal-panel rounded-[30px] p-5 sm:p-6">
          <div>
            <p class="portal-eyebrow text-[11px]">Nueva lista</p>
            <h3 class="mt-2 text-xl font-semibold text-white">Agrupar correos</h3>
          </div>

          <form action="/consultant/api/admin/manage" method="POST" class="mt-5 space-y-4">
            <input type="hidden" name="action" value="create-distribution-list" />
            <input type="hidden" name="redirect_to" value="/admin/listas-difusion" />

            <label class="block">
              <span class="mb-2 block text-sm font-medium text-white/80">Nombre</span>
              <input class="portal-input w-full rounded-2xl px-4 py-3" type="text" name="name" required />
            </label>

            <label class="block">
              <span class="mb-2 block text-sm font-medium text-white/80">Descripcion</span>
              <textarea class="portal-input min-h-28 w-full rounded-2xl px-4 py-3" name="description" placeholder="Uso interno de la lista"></textarea>
            </label>

            <label class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white/80">
              <input type="hidden" name="is_active" value="false" />
              <input type="checkbox" name="is_active" value="true" checked class="h-4 w-4" />
              Lista activa
            </label>

            <label class="block">
              <span class="mb-2 block text-sm font-medium text-white/80">Miembros</span>
              <select class="portal-input min-h-56 w-full rounded-2xl px-4 py-3" name="member_ids" multiple>
                {contacts.map((contact) => (
                  <option value={contact.id}>
                    {contact.email}
                    {contact.displayName ? ` · ${contact.displayName}` : ""}
                  </option>
                ))}
              </select>
              <p class="portal-copy mt-2 text-xs">Mantene Ctrl/Cmd para elegir varios correos.</p>
            </label>

            <button type="submit" class="portal-action-link portal-action-link--solid w-full justify-center">
              Guardar lista
            </button>
          </form>
        </article>

        <article class="portal-panel rounded-[30px] p-5 sm:p-6">
          <div class="flex items-center justify-between gap-3">
            <div>
              <p class="portal-eyebrow text-[11px]">Lista</p>
              <h3 class="mt-2 text-xl font-semibold text-white">Listas creadas</h3>
            </div>
            <span class="rounded-full border border-white/10 px-3 py-2 text-xs font-semibold uppercase tracking-[0.14em] text-white/70">
              {lists.filter((list) => list.isActive).length} activas
            </span>
          </div>

          <div class="mt-5 space-y-3">
            {lists.length === 0 ? (
              <div class="rounded-[24px] border border-white/10 bg-white/5 px-4 py-5 text-sm text-white/70">
                Aun no hay listas de difusion creadas.
              </div>
            ) : (
              lists.map((list) => (
                <details class="rounded-[24px] border border-white/10 bg-white/5 p-4">
                  <summary class="flex cursor-pointer list-none items-start justify-between gap-4">
                    <div class="min-w-0">
                      <h4 class="truncate text-base font-semibold text-white">{list.name}</h4>
                      <p class="portal-copy mt-1 text-sm">
                        {list.description ?? "Sin descripcion"}
                      </p>
                    </div>
                    <span
                      class:list={[
                        "rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.12em]",
                        list.isActive ? "bg-emerald-500/15 text-emerald-100" : "bg-white/10 text-white/60"
                      ]}
                    >
                      {list.isActive ? "Activa" : "Inactiva"}
                    </span>
                  </summary>

                  <div class="mt-4 grid gap-4">
                    <div class="grid gap-3 sm:grid-cols-3">
                      <div class="rounded-2xl bg-black/20 px-4 py-3">
                        <p class="portal-copy text-xs">Miembros</p>
                        <strong class="mt-1 block text-xl text-white">{list.memberCount}</strong>
                      </div>
                      <div class="rounded-2xl bg-black/20 px-4 py-3">
                        <p class="portal-copy text-xs">Creada</p>
                        <strong class="mt-1 block text-sm text-white">{formatDateTimeLabel(list.createdAt)}</strong>
                      </div>
                      <div class="rounded-2xl bg-black/20 px-4 py-3">
                        <p class="portal-copy text-xs">Actualizada</p>
                        <strong class="mt-1 block text-sm text-white">{formatDateTimeLabel(list.updatedAt)}</strong>
                      </div>
                    </div>

                    <div class="rounded-2xl border border-white/10 bg-black/20 px-4 py-4">
                      <p class="portal-copy text-xs uppercase tracking-[0.14em]">Correos incluidos</p>
                      <div class="mt-3 flex flex-wrap gap-2">
                        {list.memberIds.length === 0 ? (
                          <span class="text-sm text-white/60">Sin miembros cargados.</span>
                        ) : (
                          list.memberIds.map((memberId) => {
                            const contact = contactsById.get(memberId);
                            return contact ? (
                              <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-white/80">
                                {contact.email}
                              </span>
                            ) : null;
                          })
                        )}
                      </div>
                    </div>

                    <form action="/consultant/api/admin/manage" method="POST" class="space-y-4">
                      <input type="hidden" name="action" value="update-distribution-list" />
                      <input type="hidden" name="redirect_to" value="/admin/listas-difusion" />
                      <input type="hidden" name="list_id" value={list.id} />

                      <label class="block">
                        <span class="mb-2 block text-sm font-medium text-white/80">Nombre</span>
                        <input class="portal-input w-full rounded-2xl px-4 py-3" type="text" name="name" value={list.name} required />
                      </label>

                      <label class="block">
                        <span class="mb-2 block text-sm font-medium text-white/80">Descripcion</span>
                        <textarea class="portal-input min-h-28 w-full rounded-2xl px-4 py-3" name="description">{list.description ?? ""}</textarea>
                      </label>

                      <label class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white/80">
                        <input type="hidden" name="is_active" value="false" />
                        <input type="checkbox" name="is_active" value="true" checked={list.isActive} class="h-4 w-4" />
                        Lista activa
                      </label>

                      <label class="block">
                        <span class="mb-2 block text-sm font-medium text-white/80">Miembros</span>
                        <select class="portal-input min-h-56 w-full rounded-2xl px-4 py-3" name="member_ids" multiple>
                          {contacts.map((contact) => (
                            <option value={contact.id} selected={list.memberIds.includes(contact.id)}>
                              {contact.email}
                              {contact.displayName ? ` · ${contact.displayName}` : ""}
                            </option>
                          ))}
                        </select>
                        <p class="portal-copy mt-2 text-xs">Mantene Ctrl/Cmd para elegir varios correos.</p>
                      </label>

                      <div class="flex flex-wrap items-center justify-end gap-3 border-t border-white/10 pt-4">
                        <button type="submit" class="portal-action-link portal-action-link--solid">
                          Guardar cambios
                        </button>
                      </div>
                    </form>

                    <form action="/consultant/api/admin/manage" method="POST">
                      <input type="hidden" name="action" value="delete-distribution-list" />
                      <input type="hidden" name="redirect_to" value="/admin/listas-difusion" />
                      <input type="hidden" name="list_id" value={list.id} />
                      <button
                        type="submit"
                        class="portal-action-link border-red-400/25 bg-red-500/10 text-red-50 hover:border-red-300/30 hover:bg-red-500/15"
                      >
                        Eliminar lista
                      </button>
                    </form>
                  </div>
                </details>
              ))
            )}
          </div>
        </article>
      </div>
    </section>
  </div>
</AdminLayout>
